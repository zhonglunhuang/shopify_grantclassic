{% style %}
:root {
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-01: #fff;
--vtl-size-1: 1px;
--vtl-size-2: 2px;
--vtl-size-4: 4px;
--vtl-size-8: 8px;
--vtl-size-12: 12px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
--vtl-size-64: 64px;
--vtl-size-96: 96px;
--vtl-font-weight-400: 400;
--vtl-line-height-140: 1.4;
--vtl-text-decoration-none: none;
--vtl-text-decoration-underline: underline;
--vtl-border-width-1: var(--vtl-size-1);
--vtl-color-bg-fill-inverse-on-light: var(--vtl-neutral-01);
--vtl-color-text-disable-on-light: var(--vtl-neutral-70);
--vtl-space-2: var(--vtl-size-2);
--vtl-space-4: var(--vtl-size-4);
--vtl-space-8: var(--vtl-size-8);
--vtl-space-12: var(--vtl-size-12);
--vtl-space-16: var(--vtl-size-16);
--vtl-space-20: var(--vtl-size-20);
--vtl-space-24: var(--vtl-size-24);
--vtl-space-32: var(--vtl-size-32);
--vtl-space-40: var(--vtl-size-40);
--vtl-space-64: var(--vtl-size-64);
--vtl-space-96: var(--vtl-size-96);
--vtl-font-size-14: var(--vtl-size-14);
}


{% endstyle %}

<!-- --UUID-664c7c40-- -->

{%- liquid
	assign desktop_image = section.settings.image_desktop
	assign desktop_image_source = section.settings.image_source_desktop
	assign desktop_image_url = section.settings.image_desktop_url
	assign background_image = section.settings.background_image

	assign mobile_image = section.settings.image_mobile
	assign mobile_image_source = section.settings.image_source_mobile
	assign mobile_image_url = section.settings.image_mobile_url

	assign mobile_media_source = ''
	assign mobile_media_value = ''
	assign loading = "lazy"
	assign fetchpriority = "auto"
	assign preload = false
	assign desktop_media_width = 100 | minus: section.settings.text_box_width
	assign desktop_media_width = desktop_media_width | times: section.settings.section_width | divided_by: 100
	assign desktop_sizes = "(min-width: 992px) " | append: desktop_media_width | append: "vw, 0"
	assign mobile_sizes = "(min-width: 992px) 0, " | append: section.settings.section_width_mobile | append: "vw"
	assign background_sizes = "100vw"

	if mobile_image_source == 'upload' and mobile_image != blank
		assign mobile_media_source = 'upload'
		assign mobile_media_value = mobile_image
	elsif mobile_image_source == 'url' and mobile_image_url != blank
		assign mobile_media_source = 'url'
		assign mobile_media_value = mobile_image_url
	elsif desktop_image_source == 'upload' and desktop_image != blank
		assign mobile_media_source = 'upload'
		assign mobile_media_value = desktop_image
	elsif desktop_image_source == 'url' and desktop_image_url != blank
		assign mobile_media_source = 'url'
		assign mobile_media_value = desktop_image_url
	endif

	if section.index == 1
		assign loading = "eager"
		assign fetchpriority = "high"
		assign preload = true
	endif

	assign is_transparent = false
	if section.settings.text_box_background_style == 'color' and section.settings.text_box_background == 'rgba(0,0,0,0)' or section.settings.text_box_background == 'transparent' or section.settings.text_box_background == blank
		assign is_transparent = true
	elsif section.settings.text_box_background_style == 'gradient' and section.settings.text_box_background_gradient == 'rgba(0,0,0,0)' or section.settings.text_box_background_gradient == 'transparent' or section.settings.text_box_background_gradient == blank
		assign is_transparent = true
	elsif section.settings.text_box_background_style == 'border' and section.settings.border_color == 'rgba(0,0,0,0)' or section.settings.border_color == 'transparent' or section.settings.border_color == blank
		assign is_transparent = true
	endif
-%}

<section class="Vtls-{{ section.id | handle }}">
	<div
		class="VtlsImgTextContainer"
	>
		{%- if background_image != blank -%}
			<div class="VtlsImgTextContainer__BackgroundMedia" aria-hidden="true">
				{{-
					background_image
					| image_url: width: background_image.width
					| image_tag:
						class: "VtlsImgTextContainer__BackgroundImage",
						sizes: background_sizes,
						widths: "400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
						loading: loading,
						fetchpriority: fetchpriority,
						preload: preload
				-}}
				<div class="VtlsImgTextContainer__BackgroundOverlay"></div>
			</div>
		{%- endif -%}
		<div class="VtlsImgTextWrapper">
			<div class="VtlsImgText VtlsImgText--desktopPosition-{{ section.settings.image_position }} VtlsImgText--mobilePosition-{{ section.settings.image_mobile_position }}{% if section.settings.text_box_background_style == "border" %} VtlsImgText--hasBorder{% endif %} VtlsImgText--backgroundStyle-{{ section.settings.text_box_background_style }}{% if is_transparent %} VtlsImgText--isTransparentBg{% endif %}">
				<div class="VtlsImgText__Media VtlsImgText__Media--aspectRatio-{{ section.settings.aspect_ratio }}">
					{%- if desktop_image_source == 'upload' and desktop_image != blank -%}
						{{-
							desktop_image
							| image_url: width: desktop_image.width
							| image_tag:
								sizes: desktop_sizes,
								widths: "1, 400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
								fetchpriority: fetchpriority,
								loading: loading,
								preload: preload,
								class: "VtlsImgText__Media--desktop"
						-}}
					{%- elsif desktop_image_source == 'url' and desktop_image_url != blank -%}
						<img
							src="{{ desktop_image_url | escape }}"
							alt="Image with an abstract figure"
							width="1920"
							height="1080"
							loading="{{ loading }}"
							fetchpriority="{{ fetchpriority }}"
							class="VtlsImgText__Media--desktop"
						>
					{%- else -%}
						<img
							src="data:image/webp;base64,"
							alt="Image with an abstract figure"
							width="520"
							height="520"
							sizes="100vw"
							class="VtlsImgText__Media--desktop"
						>
					{%- endif -%}
					{%- if mobile_media_source == 'upload' and mobile_media_value != blank -%}
						{{-
							mobile_media_value
							| image_url: width: mobile_media_value.width
							| image_tag:
								sizes: mobile_sizes,
								widths: "1, 400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
								fetchpriority: fetchpriority,
								loading: loading,
								preload: preload,
								class: "VtlsImgText__Media--mobile"
						-}}
					{%- elsif mobile_media_source == 'url' and mobile_media_value != blank -%}
						<img
							src="{{ mobile_media_value | escape }}"
							alt="Image with an abstract figure"
							width="1920"
							height="1080"
							loading="{{ loading }}"
							fetchpriority="{{ fetchpriority }}"
							class="VtlsImgText__Media--mobile"
						>
					{%- else -%}
						<img
							src="data:image/webp;base64,"
							alt="Image with an abstract figure"
							width="520"
							height="520"
							sizes="100vw"
							class="VtlsImgText__Media--mobile"
						>
					{%- endif -%}
				</div>
				<div class="VtlsImgText__Content VtlsImgText__Content--backgroundStyle-{{ section.settings.text_box_background_style }}{% if section.settings.text_box_background_style == "gradient" and section.settings.enable_animation == true %} VtlsImgText__Content--hasAnimation{% endif %}">
					<div class="VtlsTextBox">
						{%- for block in section.blocks -%}
							{%- case block.type -%}
								{%- when "heading" -%}
									{%- if block.settings.heading_alternative_font -%}
										<style>
											{{- block.settings.heading_font | font_face: font_display: 'swap' -}}
										</style>
									{%- endif -%}
									{%- capture heading_css_variables -%}
										--block-heading-size: {{- block.settings.heading_size -}}px;
										--block-heading-color: {{- block.settings.heading_color -}};
										--block-heading-font: {{- block.settings.heading_font.family -}};
														{%- endcapture -%}
									<h2
										style="{{- heading_css_variables | strip_newlines | escape -}}"
										class="VtlsTextBox__Heading {% if block.settings.heading_alternative_font == true %}VtlsTextBox__Heading--alternativeFont{% endif %}"
										{{ block.shopify_attributes }}
									>
										{{- block.settings.heading -}}
									</h2>
								{%- when "caption" -%}
									{%- if block.settings.caption_alternative_font -%}
										<style>
											{{- block.settings.caption_font | font_face: font_display: 'swap' -}}
										</style>
									{%- endif -%}
									{%- capture caption_css_variables -%}
										--block-caption-size: {{- block.settings.caption_size -}}px;
										--block-caption-color: {{- block.settings.caption_color -}};
										--block-caption-font: {{- block.settings.caption_font.family -}};
										--block-caption-weight: {{- block.settings.caption_weight -}};
														{%- endcapture -%}
									<p
										style="{{- caption_css_variables | strip_newlines | escape -}}"
										class="VtlsTextBox__Caption {% if block.settings.caption_alternative_font == true %}VtlsTextBox__Caption--alternativeFont{% endif %}"
										{{ block.shopify_attributes }}
									>
										{{- block.settings.caption -}}
									</p>
								{%- when "text" -%}
									{%- if block.settings.description_alternative_font -%}
										{%- liquid
											assign body_font_bold = block.settings.description_font | font_modify: 'weight', 'bold'
											assign body_font_italic = block.settings.description_font | font_modify: 'style', 'italic'
											assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
										%}
										<style>
											{{- block.settings.description_font | font_face: font_display: 'swap' -}}
											{{ body_font_bold | font_face: font_display: 'swap' }}
											{{ body_font_italic | font_face: font_display: 'swap' }}
											{{ body_font_bold_italic | font_face: font_display: 'swap' }}
										</style>
									{%- endif -%}
									{%- capture description_css_variables -%}
										--block-description-size: {{- block.settings.description_size -}}px;
										--block-description-color: {{- block.settings.description_color -}};
										--block-description-font: {{- block.settings.description_font.family -}};
														{%- endcapture -%}
									<div
										style="{{- description_css_variables | strip_newlines | escape -}}"
										class="VtlsTextBox__Description VtlsTextBox__Description--alignment-{{ section.settings.text_alignment }} {% if block.settings.description_alternative_font == true %}VtlsTextBox__Description--alternativeFont{% endif %}"
										{{ block.shopify_attributes }}
									>
										{{- block.settings.description -}}
									</div>
								{%- when "buttons" -%}
									{%- capture buttons_css_variables -%}
										--block-primary-button-text-color: {{- block.settings.primary_text_color -}};
										--block-primary-button-background-color: {{- block.settings.primary_background_color -}};
										--block-primary-button-corner-radius: {{- block.settings.primary_button_corner -}}px;
										--block-primary-button-border-color: {{- block.settings.primary_border_color -}};
						
										--block-secondary-button-text-color: {{- block.settings.secondary_text_color -}};
										--block-secondary-button-background-color: {{- block.settings.secondary_background_color -}};
										--block-secondary-button-corner-radius: {{- block.settings.secondary_button_corner -}}px;
										--block-secondary-button-border-color: {{- block.settings.secondary_border_color -}};
														{%- endcapture -%}
									<div
										style="{{- buttons_css_variables | strip_newlines | escape -}}"
										class="VtlsImgTextButtons"
										{{ block.shopify_attributes }}
									>
										{%- if block.settings.primary_button_label != blank -%}
											<a
												{% if block.settings.primary_new_tab == true %}
													target="_blank"
												{% endif %}
												class="VtlsImgTextButtons__Primary VtlsImgTextButtons__Primary--{{ block.settings.primary_button_style }}"
												href="{{ block.settings.primary_button_link }}"
											>
												{{- block.settings.primary_button_label | escape -}}
											</a>
										{%- endif -%}
										{%- if block.settings.secondary_button_label != blank -%}
											<a
												{% if block.settings.secondary_new_tab == true %}
													target="_blank"
												{% endif %}
												class="VtlsImgTextButtons__Secondary VtlsImgTextButtons__Secondary--{{ block.settings.secondary_button_style }}"
												href="{{ block.settings.secondary_button_link }}"
											>
												{{- block.settings.secondary_button_label | escape -}}
											</a>
										{%- endif -%}
									</div>
							{%- endcase -%}
						{%- endfor -%}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

{% schema %}
{
	"name": "🧡 Image & Text - Simple",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Image on desktop"
		},
		{
			"type": "select",
			"id": "image_source_desktop",
			"label": "Image source",
			"options": [
				{
					"value": "upload",
					"label": "Upload"
				},
				{
					"value": "url",
					"label": "URL"
				}
			],
			"default": "upload"
		},
		{
			"type": "image_picker",
			"id": "image_desktop",
			"visible_if": "{{ section.settings.image_source_desktop == 'upload' }}",
			"label": "Image"
		},
		{
			"type": "url",
			"id": "image_desktop_url",
			"label": "Image URL",
			"visible_if": "{{ section.settings.image_source_desktop == 'url' }}"
		},
		{
			"type": "select",
			"id": "image_position",
			"label": "Position",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "left"
		},
		{
			"type": "select",
			"id": "aspect_ratio",
			"label": "Aspect ratio",
			"options": [
				{
					"value": "square",
					"label": "Square"
				},
				{
					"value": "portrait",
					"label": "Portrait"
				},
				{
					"value": "landscape",
					"label": "Landscape"
				},
				{
					"value": "original",
					"label": "Original"
				}
			],
			"default": "square"
		},
		{
			"type": "header",
			"content": "Image on mobile (optional)"
		},
		{
			"type": "select",
			"id": "image_source_mobile",
			"label": "Image source",
			"options": [
				{
					"value": "upload",
					"label": "Upload"
				},
				{
					"value": "url",
					"label": "URL"
				}
			],
			"default": "upload"
		},
		{
			"type": "image_picker",
			"id": "image_mobile",
			"label": "Image",
			"visible_if": "{{ section.settings.image_source_mobile == 'upload' }}"
		},
		{
			"type": "url",
			"id": "image_mobile_url",
			"label": "Image URL",
			"visible_if": "{{ section.settings.image_source_mobile == 'url' }}"
		},
		{
			"type": "select",
			"id": "image_mobile_position",
			"label": "Position",
			"options": [
				{
					"value": "above",
					"label": "Above content"
				},
				{
					"value": "bellow",
					"label": "Below content"
				}
			],
			"default": "above"
		},
		{
			"type": "header",
			"content": "Text box"
		},
		{
			"type": "select",
			"id": "text_alignment",
			"label": "Text alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "left"
		},
		{
			"type": "range",
			"id": "text_box_width",
			"min": 30,
			"max": 70,
			"step": 1,
			"unit": "%",
			"label": "Text box width",
			"default": 50
		},
		{
			"type": "select",
			"id": "text_box_background_style",
			"label": "Text box background",
			"options": [
				{
					"value": "color",
					"label": "Color"
				},
				{
					"value": "gradient",
					"label": "Gradient"
				},
				{
					"value": "border",
					"label": "Border"
				}
			],
			"default": "color"
		},
		{
			"type": "color",
			"id": "text_box_background",
			"label": "Text box color",
			"default": "#F3F3F3",
			"visible_if": "{{ section.settings.text_box_background_style == 'color' }}"
		},
		{
			"type": "color_background",
			"id": "text_box_background_gradient",
			"label": "Text box gradient",
			"default": "linear-gradient(to right, #fed951, #ff46c7)",
			"visible_if": "{{ section.settings.text_box_background_style == 'gradient' }}"
		},
		{
			"type": "checkbox",
			"id": "enable_animation",
			"label": "Apply animation",
			"default": false,
			"visible_if": "{{ section.settings.text_box_background_style == 'gradient' }}"
		},
		{
			"type": "color",
			"id": "border_color",
			"label": "Border color",
			"default": "#222222",
			"visible_if": "{{ section.settings.text_box_background_style == 'border' }}"
		},
		{
			"type": "range",
			"id": "text_box_corner_radius",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Corner radius",
			"default": 0
		},
		{
			"type": "header",
			"content": "Design"
		},
		{
			"type": "color",
			"id": "section_background",
			"label": "Section background"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image (optional)"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Background overlay color",
			"default": "#222222"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "%",
			"label": "Background overlay opacity",
			"default": 0
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "layout_type",
			"label": "Layout type",
			"options": [
				{
					"value": "desktop",
					"label": "Desktop"
				},
				{
					"value": "mobile",
					"label": "Mobile"
				}
			],
			"default": "desktop"
		},
		{
			"type": "range",
			"id": "section_width",
			"min": 70,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Section width",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}",
			"default": 70
		},
		{
			"type": "range",
			"id": "section_width_mobile",
			"min": 70,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Section width",	
			"visible_if": "{{ section.settings.layout_type == 'mobile' }}",
			"default": 70
		},
		{
			"type": "text",
			"id": "section_max_width",
			"label": "Custom max width (optional)",
			"info": "Section max width in pixels",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top padding",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}",
			"default": 40
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}",
			"default": 40
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top margin",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin",
			"visible_if": "{{ section.settings.layout_type == 'desktop' }}",
			"default": 0
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top padding",
			"visible_if": "{{ section.settings.layout_type == 'mobile' }}",
			"default": 20
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding",
			"visible_if": "{{ section.settings.layout_type == 'mobile' }}",
			"default": 20
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top margin",
			"visible_if": "{{ section.settings.layout_type == 'mobile' }}",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
